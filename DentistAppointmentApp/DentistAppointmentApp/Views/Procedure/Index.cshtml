@using DentistApp.ViewModels.ProcedureViewModels
@model ProcedurePaginationViewModel

@{
    ViewData["Title"] = "Procedures";
    ViewData["UsePaper"] = true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Procedures</h2>

    <form asp-action="Index" asp-controller="Procedure" method="get" class="row g-2 mb-4">
        <input type="hidden" name="page" value="1" />

        <div class="input-group">
            <span class="input-group-text">🔍</span>
            <input type="text"
                   id="searchQuery"
                   name="searchQuery"
                   value="@Model.SearchQuery"
                   class="form-control"
                   placeholder="Search by manipulation..." />
        </div>

        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>

        <div class="col-auto">
            <a asp-action="Index"
               asp-controller="Procedure"
               class="btn btn-outline-secondary">
                Clear
            </a>
        </div>
    </form>
</div>

<div class="weekly-schedule-box mb-4">
    <partial name="_WeeklyScheduleLoader" />
</div>

@if (!Model.Procedures.Any())
{
    <div class="alert alert-info">
        No Procedures found.
    </div>
}
else
{
    <div class="paper-table-wrapper">
        <table class="table table-bordered align-middle paper-table">
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Phone</th>
                    <th>Dentist</th>
                    <th>Date</th>
                    <th>Manipulation</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var procedure in Model.Procedures)
                {
                    <tr>
                        <td>@procedure.PatientProcedureName</td>
                        <td>@procedure.PatientProcedurePhoneNumber</td>
                        <td>@procedure.DentistProcedureName</td>
                        <td>@procedure.ProcedureDate</td>
                        <td>@procedure.ManipulationName</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(procedure.ProcedureDentistNote))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @procedure.ProcedureDentistNote
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Procedures pages" class="mt-4">
        <ul class="pagination justify-content-center">

            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-controller="Procedure"
                   asp-route-searchQuery="@Model.SearchQuery"
                   asp-route-page="@(Model.CurrentPage - 1)">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPagesCount; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="Procedure"
                       asp-route-searchQuery="@Model.SearchQuery"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage >= Model.TotalPagesCount ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-controller="Procedure"
                   asp-route-searchQuery="@Model.SearchQuery"
                   asp-route-page="@(Model.CurrentPage + 1)">
                    Next
                </a>
            </li>

        </ul>
    </nav>
}