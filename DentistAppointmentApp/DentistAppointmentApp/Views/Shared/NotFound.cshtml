@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-body p-5 text-center">

                    <!-- 404 Title -->
                    <div class="mb-4">
                        <div class="display-1 fw-bold text-primary">404</div>
                        <h1 class="fw-bold text-danger mb-3">Page Not Found</h1>
                        <p class="lead text-muted mb-4">
                            Oops! The page you’re looking for doesn’t exist or has been moved.
                        </p>
                    </div>

                    <div class="mb-4">
                        <i class="fas fa-tooth text-danger" style="font-size: 5rem;"></i>
                    </div>

                    <!-- Help Section -->
                    <div class="alert alert-light border rounded-3 text-start mx-auto" style="max-width: 600px;">
                        <h5 class="fw-semibold text-primary mb-3">What you can do:</h5>
                        <ul class="mb-0 ps-3">
                            <li>Check if the URL is correct</li>
                            <li>Return to the home page</li>
                            <li>Use the navigation menu to find what you need</li>
                        </ul>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                            Back to Home
                        </a>

                        <button type="button" class="btn btn-outline-secondary btn-lg px-4" onclick="history.back()">
                            Go Back
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>