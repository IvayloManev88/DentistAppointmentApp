@using DentistApp.ViewModels.FeedbackViewModels
@model IEnumerable<FeedbackViewViewModel>

@{
    ViewData["Title"] = "Patient Feedback";
    ViewData["UsePaper"] = true;
    double avgRating = ViewBag.AverageRating ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Patient Feedback</h2>
</div>

@if (Model.Any())
{
    <div class="mb-3">
        <strong>Clinic Rating:</strong>

        <span class="fs-5">
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Math.Round(avgRating))
                {
                    <span>🦷</span>
                }
                else
                {
                    <span style="opacity:0.25;">🦷</span>
                }
            }
        </span>

        <span class="text-muted ms-2">
            (@avgRating.ToString("0.0") / 5)
        </span>
    </div>
}
<div class="weekly-schedule-box mb-4">
    <partial name="_WeeklyScheduleLoader" />
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No feedback has been submitted yet.
    </div>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Patient</th>
                <th>Manipulation</th>
                <th>Rating</th>
                <th>Feedback</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var feedback in Model)
            {
                <tr>
                    <td>@feedback.ProcedurePatientName</td>

                    <td>@feedback.ProcedureManipulationType</td>

                    <td class="fs-5">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= feedback.Rating)
                            {
                                <span>🦷</span>
                            }
                            else
                            {
                                <span style="opacity:0.25;">🦷</span>
                            }
                        }
                    </td>

                    <td>@feedback.FeedbackText</td>

                    <td>@feedback.CreatedOn</td>
                </tr>
            }
        </tbody>
    </table>
}
